        property bool talk:false
        focus: true  // Ensure this item can receive keyboard events

        background: Rectangle
        {
            anchors.fill:parent
            color:"grey"//"#011026"
            opacity:1.0
            radius:100
        }
        anchors
        {
            top:sub_rect.top
