                tooltip_reset()
            }

            onPressed:
            {
            }

            onPressAndHold:
            {

            }

            onReleased:
            {

            }

            onDoubleClicked:
            {
                if(area_15.source=="qrc:/dvr_system/images/mike_on.png")
                {
                    mike_on_off.talk=false
                    area_15.source="qrc:/dvr_system/images/mike_off.png"
                    VideoStreamer.push_to_talk(true)

                }


            }


        }
